#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# claude-desktop — launcher for the RPM package and AppImage.
# Installed to /usr/bin/claude-desktop (RPM) or usr/bin/claude-desktop (AppImage).
# ---------------------------------------------------------------------------

ASAR="/usr/lib/claude-desktop/app.asar"
VERSION_FILE="/usr/lib/claude-desktop/ELECTRON_VERSION"

# ---------------------------------------------------------------------------
# Optional debug logging.
# ---------------------------------------------------------------------------
if [[ -n "${DEBUG:-}" ]]; then
    export ELECTRON_ENABLE_LOGGING=1
fi

# ---------------------------------------------------------------------------
# Stale instance cleanup (opt-in).
#
# Normal case: Electron's app.requestSingleInstanceLock() (in open-url-bridge.js)
# handles duplicate launches — the second instance sends its argv to the first
# and exits cleanly.  No pkill needed.
#
# Edge case: after a crash, a zombie electron process may hold the lock file
# without actually serving requests.  Pass --kill-stale to force-kill any
# previous electron process that was started with this ASAR before launching.
# Only the main process is matched (--oldest), not renderers or GPU helpers.
# ---------------------------------------------------------------------------
if [[ "${1:-}" == "--kill-stale" ]]; then
    shift
    pkill --oldest -f "electron.*$(basename "$ASAR")" 2>/dev/null || true
    sleep 0.2
fi

# ---------------------------------------------------------------------------
# Locate Electron — bundled copy first, then system PATH.
# A bundled copy lives next to the asar when packaged inside an AppImage.
# ---------------------------------------------------------------------------
ELECTRON=""

# Bundled: same lib directory as the asar, or an explicit sub-directory.
for candidate in \
    "$(dirname "$ASAR")/electron/electron" \
    "/usr/lib/electron/electron" \
    "/usr/lib64/electron/electron"; do
    if [[ -x "$candidate" ]]; then
        ELECTRON="$candidate"
        break
    fi
done

# Fall back to whatever is on PATH.
if [[ -z "$ELECTRON" ]]; then
    if command -v electron &>/dev/null; then
        ELECTRON="$(command -v electron)"
    else
        REQUIRED_VER=""
        [[ -f "$VERSION_FILE" ]] && REQUIRED_VER="$(cat "$VERSION_FILE")"
        echo "[claude-desktop] ERROR: 'electron' binary not found." >&2
        echo "  Required version: ${REQUIRED_VER:-unknown}" >&2
        echo "  Install with:  sudo dnf install electron" >&2
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Cowork service check (optional — Cowork/Dispatch via socket protocol).
# ---------------------------------------------------------------------------
if ! pgrep -x cowork-svc-linux &>/dev/null && \
   { ! command -v systemctl &>/dev/null || ! systemctl --user is-active claude-cowork &>/dev/null 2>&1; }; then
    echo "[claude-desktop] WARN: claude-cowork service not running. Socket-based and Dispatch Cowork features will be unavailable." >&2
    echo "  Other Cowork backends (stub/bwrap/host) remain functional." >&2
    echo "  Run: scripts/install-cowork-service.sh" >&2
fi

# ---------------------------------------------------------------------------
# Cowork backend selection.
# ---------------------------------------------------------------------------
COWORK_BACKEND="${COWORK_BACKEND:-bubblewrap}"
export COWORK_BACKEND

if [[ "$COWORK_BACKEND" == "bubblewrap" ]] && ! command -v bwrap &>/dev/null; then
    echo "[claude-desktop] WARNING: bwrap not found. Falling back to COWORK_BACKEND=host." >&2
    echo "  Install: sudo dnf install bubblewrap" >&2
    export COWORK_BACKEND=host
fi

# ---------------------------------------------------------------------------
# Ensure the session directory exists (no /sessions symlink needed —
# path-translator.mjs handles all /sessions/… → ~/.local/share/… remapping).
# ---------------------------------------------------------------------------
mkdir -p "$HOME/.local/share/claude-linux/sessions"

# ---------------------------------------------------------------------------
# D-Bus: start a temporary daemon when the system bus socket is missing.
# Containers, distrobox, WSL, and minimal installs often lack a system bus,
# which causes Chromium to spam stderr with harmless connection errors.
# ---------------------------------------------------------------------------
if [[ ! -S /run/dbus/system_bus_socket ]] && [[ -z "${DBUS_SYSTEM_BUS_ADDRESS:-}" ]]; then
    if command -v dbus-daemon &>/dev/null; then
        _dbus_tmp="$(mktemp -d "${TMPDIR:-/tmp}/claude-dbus.XXXXXX")"
        _dbus_addr="unix:path=${_dbus_tmp}/bus"
        _dbus_pid="$(dbus-daemon --fork --session --address="$_dbus_addr" --print-pid 2>/dev/null)" || true
        if [[ -n "$_dbus_pid" ]]; then
            export DBUS_SYSTEM_BUS_ADDRESS="$_dbus_addr"
            trap 'kill $_dbus_pid 2>/dev/null; rm -rf "$_dbus_tmp"' EXIT
            echo "[claude-desktop] INFO: Started temporary D-Bus daemon (system bus unavailable)" >&2
        else
            rm -rf "$_dbus_tmp"
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Ensure menuBarEnabled is set in config (updates reset it).
# ---------------------------------------------------------------------------
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/Claude"
CONFIG_FILE="$CONFIG_DIR/config.json"

if [[ ! -f "$CONFIG_FILE" ]]; then
  mkdir -p "$CONFIG_DIR"
  echo '{"menuBarEnabled":true}' > "$CONFIG_FILE"
elif ! grep -q '"menuBarEnabled"[[:space:]]*:[[:space:]]*true' "$CONFIG_FILE" 2>/dev/null; then
  if command -v jq &>/dev/null; then
    TMP="$(mktemp)" || TMP=""
    if [[ -n "$TMP" ]]; then
      if jq '.menuBarEnabled = true' "$CONFIG_FILE" > "$TMP" 2>/dev/null; then
        mv "$TMP" "$CONFIG_FILE"
      else
        echo "[claude-desktop] WARNING: Could not update config.json with jq (is it valid JSON?); leaving unchanged." >&2
        rm -f "$TMP"
      fi
    fi
  elif grep -q '"menuBarEnabled"' "$CONFIG_FILE" 2>/dev/null; then
    sed -i 's/"menuBarEnabled"[[:space:]]*:[[:space:]]*[^,}]*/"menuBarEnabled":true/' "$CONFIG_FILE"
  else
    sed -i 's/^{/{\"menuBarEnabled\":true,/' "$CONFIG_FILE"
  fi
fi

# ---------------------------------------------------------------------------
# Launch.
# --no-sandbox is required:
#   • AppImage: FUSE nosuid prevents chrome-sandbox setuid.
#   • Hardened systems: chrome-sandbox may lack the setuid bit.
# ---------------------------------------------------------------------------
exec "$ELECTRON" --no-sandbox "$ASAR" "$@"
